{
  "name": "ecoguide-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate --schema=backend/prisma/schema.prisma",
    "build": "prisma generate --schema=backend/prisma/schema.prisma",
    "start": "prisma migrate deploy --schema=backend/prisma/schema.prisma && node backend/src/index.js",
    "lint": "npm run lint --prefix frontend && npm run lint --prefix backend",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --prefix backend && npm run test --prefix frontend"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.22.4",
    "prisma": "^5.9.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
